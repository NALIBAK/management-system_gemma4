# Copy this file to .env and fill in your values
# cp .env.example .env  (Linux/macOS)
# copy .env.example .env  (Windows)

FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-super-secret-key-change-this

# XAMPP MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=          # Leave blank for default XAMPP (no root password)
DB_NAME=college_management

# JWT
JWT_SECRET=your-jwt-secret-key-change-this
JWT_EXPIRY_HOURS=24

# CORS — add your frontend origin here (required to avoid CORS errors in browser)
# For local development via Python HTTP server on port 8000:
CORS_ORIGINS=http://localhost:8000,http://localhost,http://127.0.0.1,http://127.0.0.1:8000

# Offline-First AI (Gemma 4 Good Hackathon)
AI_MODE=local
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma4:4b
